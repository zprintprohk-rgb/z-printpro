# 智印港 Z-PrintPro 环境变量配置
# 复制此文件为 .env.local 并填写实际值

# ==========================================
# Next.js 配置
# ==========================================

# 网站 URL（生产环境）
NEXT_PUBLIC_SITE_URL=https://z-printpro.pages.dev

# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh-HK

# ==========================================
# Supabase 配置
# ==========================================

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名公开密钥
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 服务角色密钥（仅服务端使用）
SUPABASE_SERVICErole_KEY=your-service-role-key-here

# ==========================================
# Cloudflare 配置（可选）
# ==========================================

# Cloudflare Account ID（用于 Pages 部署）
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare API Token（用于自动部署）
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ==========================================
# Stripe 配置（支付集成，可选）
# ==========================================

# Stripe 发布密钥
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe 密钥（仅服务端使用）
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ==========================================
# Google 配置（可选）
# ==========================================

# Google Analytics 测量 ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console 验证码
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# ==========================================
# 开发环境配置
# ==========================================

# 开发模式
NODE_ENV=development

# 端口
PORT=3000